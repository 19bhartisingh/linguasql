# ══════════════════════════════════════════════════════
#  QueryMind — Environment Variables Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your keys & settings
#  3. NEVER commit the .env file to Git!
# ══════════════════════════════════════════════════════

# ── AI Provider Keys ────────────────────────────────────

# Google Gemini (FREE tier — recommended)
GEMINI_API_KEY=your_gemini_key_here

# OpenAI GPT (Paid)
OPENAI_API_KEY=your_openai_key_here

# Groq LLaMA (FREE tier — very fast)
GROQ_API_KEY=your_groq_key_here

# ── Scheduled Email Reports ─────────────────────────────
# Required to send scheduled reports via email.
# Leave blank to disable email (reports still run manually).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=QueryMind Reports <you@gmail.com>
SMTP_TLS=true

# ── Security ────────────────────────────────────────────
# Encrypts stored API keys. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
QM_SECRET_KEY=change-me-to-a-random-32-char-secret!!

# JWT signing secret for user authentication.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
QM_JWT_SECRET=change-me-to-a-different-random-64-hex-chars
QM_JWT_EXPIRE_DAYS=30

# ── Server ──────────────────────────────────────────────
PORT=8000
